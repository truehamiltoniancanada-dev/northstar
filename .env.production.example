# Frontend
VITE_API_BASE_URL=https://api.sentryharbor.com/api

# Backend
PORT=8787
APP_URL=https://www.sentryharbor.com
API_BASE_URL=https://api.sentryharbor.com
CORS_ORIGIN=https://www.sentryharbor.com
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# Production database
DATABASE_URL=postgres://user:password@host:5432/sentryharbor

# Stripe live mode
STRIPE_SECRET_KEY=sk_liv…here
STRIPE_WEBHOOK_SECRET=whsec_…here
STRIPE_PRICE_ID=price_your_monthly_subscription_price_id

# OpenAI
OPENAI_API_KEY=your_o…here
OPENAI_MODEL=gpt-4.1-mini

# Composio tool access for the chat agent
COMPOSIO_API_KEY=your_composio_api_key_here
# Optional comma-separated toolkit allowlist, for example: gmail,googlecalendar,slack
COMPOSIO_TOOLKITS=
COMPOSIO_MAX_TOOL_ITERATIONS=3

# Email provider
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=Sentryharbor <hello@sentryharbor.com>
SENDGRID_API_KEY=SG.you…here

# Production auth behavior
DEV_AUTH_CODES=false
DEPLOY_WEBHOOK_URL=https://api.sentryharbor.com/api/deploy-events
DEPLOY_WEBHOOK_TOKEN=replac…oken
